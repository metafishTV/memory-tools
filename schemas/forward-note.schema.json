{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "forward-note.schema.json",
  "title": "Forward Note Entry",
  "description": "A single forward note in forward_notes.json.",
  "type": "object",
  "required": ["source", "description", "status", "date"],
  "properties": {
    "source": {
      "type": "string",
      "description": "Source label that contributed this note."
    },
    "description": {
      "type": "string",
      "description": "One-line description from interpretation."
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "accepted", "implemented", "superseded", "merged_into", "bookmarked"],
      "description": "Lifecycle status. 'bookmarked' for design doc notes."
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date when entry was created."
    },
    "origin": {
      "type": "string",
      "description": "Provenance label (e.g. 'design_doc', source label)."
    },
    "cross_references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "description", "date"],
        "properties": {
          "source": { "type": "string" },
          "description": { "type": "string" },
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      },
      "description": "Cross-references to related sources discovered after initial note creation."
    },
    "merged_into": {
      "type": "string",
      "description": "Note ID this note was merged into."
    },
    "merged_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date when the merge happened."
    }
  },
  "additionalProperties": false
}

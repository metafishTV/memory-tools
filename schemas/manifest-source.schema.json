{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest-source.schema.json",
  "title": "Manifest Source Entry",
  "description": "A per-source entry in manifest.json.",
  "$comment": "Early sources (pre-pipeline) may have empty strings for date_distilled, source_type, and relationship. Schemas accept empty string as valid for these fields.",
  "type": "object",
  "required": ["concepts", "forward_notes", "cw_ids", "metrics", "iteration", "open_questions", "resolved_by", "resolves"],
  "properties": {
    "date_distilled": {
      "type": "string",
      "description": "ISO date of distillation, or empty string for pre-pipeline sources."
    },
    "source_type": {
      "type": "string",
      "enum": ["PDF", "web", "image", "recording", ""],
      "description": "Source format type, or empty string for pre-pipeline sources."
    },
    "extraction_route": {
      "type": "string",
      "description": "Route code (A-G for PDF, W for web, I for image, R for recording)."
    },
    "register": {
      "type": "string",
      "description": "Domain register (e.g. empirical, continental, practitioner)."
    },
    "distillation_file": {
      "type": "string",
      "description": "Path to distilled content file."
    },
    "interpretation_file": {
      "type": "string",
      "description": "Path to interpretation file."
    },
    "concepts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "maps_to": { "type": "string" },
          "relationship": {
            "type": "string",
            "enum": ["confirms", "extends", "challenges", "novel", ""],
            "description": "Relationship type, or empty string for pre-pipeline sources."
          },
          "alpha_id": {
            "type": "string",
            "description": "Alpha entry ID (w:N format), or empty string if not yet integrated."
          },
          "information_gain": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "forward_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cw_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^cw:\\d+$" }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "concept_density": { "type": "number", "minimum": 0 },
        "coverage_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "cross_ref_density": { "type": "number", "minimum": 0 },
        "forward_note_yield": { "type": "number", "minimum": 0 },
        "convergence_contribution": { "type": "number", "minimum": 0, "maximum": 1 },
        "composite_quality": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "iteration": {
      "type": "integer",
      "minimum": 1
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "resolved_by": {
      "type": "array",
      "items": { "type": "string" }
    },
    "resolves": {
      "type": "array",
      "items": { "type": "string" }
    },
    "redistill_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "mode", "concept_count"],
        "properties": {
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "mode": { "type": "string", "enum": ["archive", "update", "delete"] },
          "concept_count": { "type": "integer", "minimum": 0 },
          "changelog_path": { "type": "string" }
        },
        "additionalProperties": false
      },
      "description": "History of re-distillation passes."
    }
  },
  "additionalProperties": false
}

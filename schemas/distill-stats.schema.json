{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "distill-stats.schema.json",
  "title": "Distillation Stats",
  "description": "The .distill_stats temporary file produced by extract and consumed by integrate.",
  "type": "object",
  "required": ["source_label", "source_type", "extraction_date"],
  "properties": {
    "source_label": {
      "type": "string",
      "description": "Source label matching manifest key."
    },
    "source_type": {
      "type": "string",
      "enum": ["PDF", "web", "image", "recording"]
    },
    "extraction_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "pages": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "text": { "type": "integer", "minimum": 0 },
        "tables": { "type": "integer", "minimum": 0 },
        "complex_layout": { "type": "integer", "minimum": 0 },
        "scanned": { "type": "integer", "minimum": 0 },
        "equations": { "type": "integer", "minimum": 0 },
        "image_pages": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "figures": {
      "type": "object",
      "properties": {
        "extracted": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "verification_passed": { "type": "integer", "minimum": 0 },
        "verification_failed": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "routes_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tools_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scan_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "redistill_mode": {
      "oneOf": [
        { "type": "string", "enum": ["archive", "update", "delete"] },
        { "type": "null" }
      ],
      "description": "Null for first-time distillation, or redistill mode."
    }
  },
  "additionalProperties": false
}

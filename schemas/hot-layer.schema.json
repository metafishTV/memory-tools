{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hot-layer.schema.json",
  "title": "Hot Layer (Handoff)",
  "description": "The handoff.json structure written by buffer:off skill.",
  "$comment": "Production handoffs may use 'layer' instead of 'scope' (older field name). Extra reference fields (alpha_ref, warm_ref, cold_ref) are permitted.",
  "type": "object",
  "required": ["schema_version", "buffer_mode", "session_meta", "active_work", "open_threads", "recent_decisions", "instance_notes", "memory_config", "natural_summary"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "buffer_mode": {
      "type": "string",
      "enum": ["lite", "project"]
    },
    "scope": {
      "type": "string",
      "enum": ["lite", "full"],
      "description": "Normalized scope value. May be absent if 'layer' is used instead."
    },
    "layer": {
      "type": "string",
      "description": "Legacy field name for scope. Older handoffs use this."
    },
    "alpha_ref": {
      "type": "string",
      "description": "Reference path to alpha bin."
    },
    "warm_ref": {
      "type": "string",
      "description": "Reference path to warm layer."
    },
    "cold_ref": {
      "type": "string",
      "description": "Reference path to cold layer."
    },
    "remote_backup": {
      "type": "boolean"
    },
    "sessions_since_full_scan": {
      "type": "integer",
      "minimum": 0
    },
    "full_scan_threshold": {
      "type": "integer",
      "minimum": 1
    },
    "session_meta": {
      "type": "object",
      "required": ["date", "commit", "branch"],
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "commit": { "type": "string" },
        "branch": { "type": "string" },
        "files_modified": { "type": "array", "items": { "type": "string" } },
        "tests": { "type": "string" }
      },
      "additionalProperties": false
    },
    "orientation": {
      "type": "object",
      "description": "Orientation data for full scope."
    },
    "active_work": {
      "type": "object",
      "required": ["current_phase", "completed_this_session", "in_progress", "blocked_by", "next_action"],
      "properties": {
        "current_phase": { "type": "string" },
        "completed_this_session": { "type": "array", "items": { "type": "string" } },
        "in_progress": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "blocked_by": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "next_action": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "open_threads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["thread", "status"],
        "properties": {
          "thread": { "type": "string" },
          "status": { "type": "string" },
          "see": { "type": "array", "items": { "type": "string" } },
          "ref": { "oneOf": [{ "type": "array", "items": { "type": "string" } }, { "type": "string" }], "description": "Alpha entry references or context note (legacy field name for 'see')." }
        },
        "additionalProperties": false
      }
    },
    "recent_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["what", "chose", "why", "session"],
        "properties": {
          "what": { "type": "string" },
          "chose": { "type": "string" },
          "why": { "type": "string" },
          "session": { "type": "string" },
          "see": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "instance_notes": {
      "type": "object",
      "required": ["from", "to", "remarks", "open_questions"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "remarks": { "type": "array", "items": { "type": "string" } },
        "open_questions": { "type": "array", "items": { "type": "string" } },
        "alpha_accessed": { "type": "array", "items": { "type": "string" }, "description": "Alpha entries accessed during the session." },
        "dialogue_style": {
          "type": "string",
          "description": "1-2 sentence characterization of session conversational register. Adopted silently by next instance."
        }
      },
      "additionalProperties": false
    },
    "concept_map_digest": {
      "type": "object",
      "properties": {
        "_meta": {
          "type": "object",
          "properties": {
            "total_entries": { "type": "integer" },
            "last_validated": { "type": "string" }
          }
        },
        "recent_changes": {
          "type": "array",
          "items": { "type": "object" }
        },
        "flagged": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "object" },
              { "type": "string", "description": "Entry ID flagged for review." }
            ]
          }
        }
      }
    },
    "convergence_web_digest": {
      "type": "object",
      "properties": {
        "_meta": {
          "type": "object",
          "properties": {
            "total_entries": { "type": "integer" }
          }
        },
        "clusters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "flagged": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "object" },
              { "type": "string" }
            ]
          }
        }
      }
    },
    "memory_config": {
      "type": "object",
      "required": ["integration"],
      "properties": {
        "integration": { "type": "string", "enum": ["none", "full"] },
        "path": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "natural_summary": {
      "type": "string",
      "description": "Human-readable session summary."
    },
    "football_in_flight": {
      "type": "boolean",
      "description": "Soft guard: true while a football is in flight to a worker session."
    }
  },
  "additionalProperties": false
}

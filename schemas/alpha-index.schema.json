{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alpha-index.schema.json",
  "title": "Alpha Index",
  "description": "The alpha bin index.json structure containing all w: and cw: entries.",
  "$comment": "Matches production format (schema_version 1). Framework entries may lack 'type' and 'file' fields; framework sources have 'groups' instead of ID arrays.",
  "type": "object",
  "required": ["schema_version", "last_updated", "entries", "sources", "concept_index", "source_index", "summary"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Current production version is 1."
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date when the index was first created."
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date of last modification."
    },
    "rebuilt": {
      "type": "boolean",
      "description": "True if index was rebuilt from files on disk."
    },
    "schema_notes": {
      "type": "object",
      "description": "Explanatory notes about index conventions.",
      "additionalProperties": true
    },
    "reinforcement": {
      "type": "object",
      "description": "Per-entry reinforcement scores from sigma hook feedback.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "degree": { "type": "number" },
          "source_diversity": { "type": "number" },
          "is_prime": { "type": "boolean" },
          "ref_count": { "type": "integer", "minimum": 0 },
          "last_ref": {
            "oneOf": [
              { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              { "type": "null" }
            ]
          },
          "trend": { "type": "string", "enum": ["rising", "stable", "falling"] }
        },
        "additionalProperties": false
      }
    },
    "entries": {
      "type": "object",
      "patternProperties": {
        "^(w|cw):\\d+$": {
          "type": "object",
          "required": ["source", "concept"],
          "properties": {
            "source": {
              "type": "string",
              "description": "Source folder name."
            },
            "file": {
              "type": "string",
              "description": "Relative path to .md file."
            },
            "concept": {
              "type": "string",
              "description": "Concept key used for indexing."
            },
            "type": {
              "type": "string",
              "enum": ["cross_source", "convergence_web"],
              "description": "Entry type. May be absent on older framework entries."
            },
            "origin": {
              "type": "string",
              "enum": ["distill", "session"]
            },
            "group": {
              "type": "string",
              "description": "Framework group letter (A, P, T, S, etc.). Present on _framework entries."
            },
            "convergence_tag": {
              "type": "string",
              "enum": ["complementarity", "independent_convergence", "genealogy", "elaboration", "tension", "wall", "same_source_deepening"],
              "description": "Synthesis tag for cw: entries (without brackets)."
            },
            "redirected_to": {
              "type": "string",
              "description": "Entry ID this entry was redirected/merged into."
            },
            "distillation": {
              "type": "string",
              "description": "Filename of distillation source document."
            },
            "marker": {
              "type": "string",
              "description": "Concept key matching CONCEPT marker in distillation file."
            },
            "redistill_archived": {
              "type": "string",
              "description": "ISO date when entry was archived by redistillation."
            },
            "orphaned_by_redistill": {
              "type": "string",
              "description": "ISO date when entry was orphaned by redistillation."
            },
            "supersedes": {
              "type": "string",
              "description": "w:ID of older entry this one supersedes."
            },
            "superseded_by": {
              "type": "string",
              "description": "w:ID of newer entry that supersedes this one."
            },
            "dangling": {
              "type": "string",
              "description": "Note about a deleted reference in a cw: entry."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["folder", "entry_count"],
        "properties": {
          "folder": { "type": "string" },
          "framework": {
            "type": "boolean",
            "description": "True for the _framework pseudo-source."
          },
          "groups": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Framework group letters. Present only on _framework source."
          },
          "cross_source_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^w:\\d+$" }
          },
          "convergence_web_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^cw:\\d+$" }
          },
          "entry_count": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "concept_index": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "pattern": "^(w|cw):\\d+$" }
      }
    },
    "source_index": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "pattern": "^(w|cw):\\d+$" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_cross_source", "total_convergence_web", "total_framework", "total_sources"],
      "properties": {
        "total_cross_source": { "type": "integer", "minimum": 0 },
        "total_convergence_web": { "type": "integer", "minimum": 0 },
        "total_framework": { "type": "integer", "minimum": 0 },
        "total_sources": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true,
  "$comment-additionalProperties": "Top-level allows computed fields (clusters, cw_graph, wholeness, etc.) added by grid rebuild and other scripts."
}
